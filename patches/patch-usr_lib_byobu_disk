--- a/usr/lib/byobu/disk	2026-03-11 01:59:03.746789290 -0400
+++ b/usr/lib/byobu/disk	2026-03-11 02:19:43.358330625 -0400
@@ -28,7 +28,13 @@
 	# Default to /, but let users override
 	[ -z "$MONITORED_DISK" ] && MP="/" || MP="$MONITORED_DISK"
 	case $MP in
